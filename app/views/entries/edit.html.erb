<%= turbo_frame_tag(params[:input]) do %>
  <%= form_with(model: @entry, class: "d-flex position-relative") do |form| %>
    <div class="form-floating edit-name">
      <%= form.text_field :name, class: "form-control", placeholder: "Name" %>
      <%= form.label :name, class: "fw-bold text-dark" %>
    </div>
    <div class="form-floating edit-url">
      <%= form.text_field :url, class: "form-control", placeholder: "http://www.example.com" %>
      <%= form.label :url, class: "fw-bold text-dark" %>
    </div>
    <div class="form-floating edit-username">
      <%= form.text_field :username, class: "form-control", placeholder: "Username" %>
      <%= form.label :username, class: "fw-bold text-dark" %>
    </div>
    <div class="form-floating edit-password">
      <%= form.text_field :password, class: "form-control", placeholder: "Password" %>
      <%= form.label :password, class: "fw-bold text-dark" %>
    </div>
    <div class="entry-edit-actions">
      <%= form.button(class: "btn btn-sm btn-outline-success me-2 rounded-circle") do %>
        <i class="bi bi-check-lg"></i>
      <% end %>
      <%= link_to entry_path(@entry), class: "btn btn-sm btn-outline-danger rounded-circle" do %>
        <i class="bi bi-x-lg"></i>
      <% end %>
    </div>
  <% end %>
<% end %>
