<%= turbo_frame_tag("main-dashboard") do %>
  <div class="d-flex align-items-center justify-content-between">
    <h1>New Entry</h1>
    <%= link_to "Cancel", entries_path, class: "btn btn-sm btn-outline-danger" %>
  </div>
  <div class="row">
    <div class="column">
      <div class="card">
        <div class="card-body">
          <% if @entry.errors.any? %>
            <div id="error_explanation" class="alert alert-danger" role="alert">
              <h4>Please fix the following <%= pluralize(@entry.errors.count, "error") %> below and try again.</h4>
              <ul>
                <% @entry.errors.each do |error| %>
                  <li><%= error.full_message %></li>
                <% end %>
              </ul>
            </div>
          <% end %>
          <%= form_with(model: @entry) do |form| %>
            <div class="form-floating mb-3">
              <%= form.text_field :name, class: "form-control", placeholder: "Name" %>
              <%= form.label :name, class: "form-label" %>
            </div>
            <div class="form-floating mb-3">
              <%= form.text_field :url, class: "form-control", placeholder: "http://www.example.com" %>
              <%= form.label :url, class: "form-label" %>
            </div>
            <div class="form-floating mb-3">
              <%= form.text_field :username, class: "form-control", placeholder: "Username" %>
              <%= form.label :username, class: "form-label" %>
            </div>
            <div class="form-floating mb-3">
              <%= form.text_field :password, class: "form-control", placeholder: "Password" %>
              <%= form.label :password, class: "form-label" %>
            </div>
            <%= form.submit "Create New Entry", class: "btn btn-primary" %>
          <% end %>
        </div>
      </div>
    </div>
  </div>
<% end %>