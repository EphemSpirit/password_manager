<div class="row">
  <div class="entries-actions card">
    <div class="entry-search" data-controller="search">
      <%= form_with(url: entries_path, method: :get, data: { turbo_frame: "search-results"}, class: "position-relative") do |f| %>
        <div class="form-floating">
          <%= f.text_field(:name, placeholder: "Search", class: "form-control", data: { action: "input->search#toggleClearButton"}) %>
          <%= f.label(:search, for: :name) %>
        </div>
        <div class="entry-search-button">
          <%= link_to root_path, class: "btn btn-small btn-outline-danger rounded-circle p-0 lh-1 me-2 d-none", data: { search_target: "clearButton" } do %>
            <i class="bi bi-x"></i>
          <% end %>
          <%= f.button(class: "btn btn-primary") do %>
            <i class="bi bi-search"></i>
          <% end %>
        </div>
      <% end %>
    </div>
    <%= link_to("+ New Entry", new_entry_path, class: "btn btn-primary", data: { turbo_frame: "main-dashboard" }) %>
  </div>
  <div class="card shadow-sm" id="dashboard">
    <div class="entries-card">
      <div class="entries-card__sidebar">
        <%= turbo_frame_tag("search-results") do %>
          <nav class="nav flex-column" id="entries-list">
            <% if @entries.any? %>
              <%= render @entries %>
            <% end %>
          </nav>
        <% end %>
      </div>
      <div class="entries-card__main">
        <%= turbo_frame_tag("main-dashboard") do %>
          <% if @entries.any? %>
            <%= render(partial: "entries/main", locals: { entry: @main_entry }) %>
          <% else %>
            <%= render(html: content_tag(:h1, "No entries", class: "h-100 d-flex align-items-center justify-content-center"))%>
          <% end %>
        <% end %>
      </div>
    </div>
  </div>
</div>